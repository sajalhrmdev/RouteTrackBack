generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Company {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  departments   Department[]
  designations  Designation[]
  employees     Employee[]
  attendances   Attendance[]
  gpsLocations  GpsLocation[]
  liveLocations LiveLocation[]
  notifications Notification[]
}

model User {
  id           String   @id @default(uuid())
  companyId    String
  email        String   @unique
  password     String
  role         Role     @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  refreshToken String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
}

model Employee {
  id              String         @id @default(uuid())
  companyId       String
  employeeId      String         @unique
  name            String
  email           String         @unique
  phone           String?
  avatar          String?
  status          EmployeeStatus @default(ACTIVE)
  departmentId    String?
  designationId   String?
  reportingManagerId String?
  isOnline        Boolean        @default(false)
  lastLocationAt  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company          Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  department       Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designation      Designation?  @relation(fields: [designationId], references: [id], onDelete: SetNull)
  reportingManager Employee?     @relation("EmployeeManager", fields: [reportingManagerId], references: [id])
  subordinates     Employee[]    @relation("EmployeeManager")
  attendances      Attendance[]
  gpsLocations     GpsLocation[]
  liveLocation     LiveLocation?

  @@index([companyId])
  @@index([employeeId])
  @@index([email])
  @@index([departmentId])
  @@index([designationId])
}

model Department {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Designation {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([companyId, name])
  @@index([companyId])
}

model Attendance {
  id              String           @id @default(uuid())
  companyId       String
  employeeId      String
  checkInTime     DateTime
  checkOutTime    DateTime?
  status          AttendanceStatus @default(CHECKED_IN)
  checkInLat      Float?
  checkInLng      Float?
  checkOutLat     Float?
  checkOutLng     Float?
  checkInAddress  String?
  checkOutAddress String?
  totalDistance   Float            @default(0)
  totalWorkingTime Int             @default(0)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company    Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  gpsRecords GpsLocation[] @relation("AttendanceGps")
  liveLocation LiveLocation?

  @@index([companyId])
  @@index([employeeId])
  @@index([checkInTime])
  @@index([status])
}

model GpsLocation {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String
  attendanceId String?
  latitude    Float
  longitude   Float
  accuracy    Float?
  speed       Float?
  heading     Float?
  batteryLevel Float?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendance Attendance? @relation("AttendanceGps", fields: [attendanceId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([employeeId])
  @@index([attendanceId])
  @@index([timestamp])
}

model LiveLocation {
  id          String   @id @default(uuid())
  companyId   String
  employeeId  String   @unique
  attendanceId String  @unique
  latitude    Float
  longitude   Float
  accuracy    Float?
  speed       Float?
  heading     Float?
  batteryLevel Float?
  timestamp   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  attendance Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
}

model Notification {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
